<h2>Reports for {{company}}</h2>


<table>
    <tr>
        <th>Report ID</th>
        <th>Title</th>
        <th>Date</th>
        <th>Description</th>
        <th>File URL</th>
    </tr>
    {{#each data as |report|}}
    <tr>
        <td>{{report.report_id}}</td>
        <td>{{report.title}}</td>
        <td>{{report.date}}</td>
        <td>{{report.description}}</td>
        <td><a href="{{report.file_url}}" target="_blank">Download</a></td>
    </tr>
    {{/each}}
</table>