<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body,
        html {
            margin: 0;
            padding: 0;
            height: 100%;
            display: flex;
            flex-direction: row;
            /* This ensures children are laid out in a row */
            width: 100%;
            font-family: Inter, -apple-system, system-ui, BlinkMacSystemFont, Arial, sans-serif;
        }

        #sidebar {
            width: 250px;
            /* Adjust the sidebar width as needed */
            background: #white;
            color: darkgray;
            height: 100%;
            border-right: 1px solid #E2E8F0;
        }

        #sidebar hr {
            margin: 20px;
            border: 0;
            border-top: 1px solid #E2E8F0;
        }

        #sidebar ul {
            list-style: none;
            margin-right: 20px;
            padding: 0;
        }

        #sidebar ul li {
            margin-bottom: 10px;
            padding: 10px;
            border-top-right-radius: 20px;
            border-bottom-right-radius: 20px;
            cursor: pointer;
        }

        #sidebar ul li:hover {
            background-color: #E2E8F0;
        }

        #sidebar ul .selected {
            background-color: #E2E8F0;
        }

        #sidebar ul li a {
            text-decoration: none;
            color: black;
            margin-left: 5px;
        }

        #sidebar ul li i {
            margin-left: 20px;
            color: black;
        }

        #content {
            flex-grow: 1;
            /* This makes the content area take up the remaining space */
            background: #EBEFF2;
        }

        #menu-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #EBEFF2;
            border-bottom: 1px solid #aeb3b9;
        }

        #user-profile {
            text-align: center;
            margin-bottom: 40px;
            margin-top: 20px;
        }

        #profile-pic {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            margin-bottom: 5px;
        }

        #user-name {
            /* Additional styling for the user name text */
            color: black;
            font-weight: bold;
            font-size: smaller;
        }

        #company-profile {
            margin-top: 20px;
        }

        #company-logo {
            margin-left: 20px;
            height: 80px;
            margin-bottom: 0px;
        }

        .company-block-parent {
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-top: 40px;
            /* Add any additional styling for the parent container */
        }

        .company-block {
            width: 60%;
            /* Additional styling for the company block */
        }

        .company-block .container {
            width: 100%;
            margin: 0 auto;
            background-color: white;
            border: 1px solid #ccc;
            box-shadow: 2px 2px 5px rgba(0, 0, 0, 0.3);
        }

        .company-block .title-bar {
            background-color: #ccc;
            padding: 10px;
        }

        .company-block .main-section {
            background-color: white;
            padding: 20px;
        }

        .company-block .button-container {
            margin-top: 20px;
            align-items: center;
            text-align: center;
        }

        .company-block .button {
            width: 80%;
            background-color: #ccc;
            border: 1px solid #999;
            padding: 10px;
            text-align: center;
            font-weight: bold;
            cursor: pointer;
            margin: 0 auto; 
            margin-bottom: 20px;
            /* Adds space between buttons */
        }

        .company-block .button:hover {
            background-color: #bbb;
        }
    </style>
</head>

<body>
    <div id="sidebar">
        <div id="company-profile">
            <img src="/images/{{company}}.png" alt="{{company}} Logo" id="company-logo">
        </div>

        <div id="user-profile">
            <img src="{{user.imageUrl}}" alt="User Profile Picture" id="profile-pic">
            <div id="user-name">{{user.firstName}} {{user.lastName}}</div>
        </div>

        <hr />
        <ul>
            <li><i class="bi-house-door"></i><a href="/">Home</a></li>
            <li><i class="bi-people"></i><a href="/users">Users</a></li>
            <li><i class="bi-file-bar-graph"></i><a href="/reports">Reports</a></li>
            <li><i class="bi-suitcase-lg"></i><a href="/admin">Admin</a></li>
            <li><i class="bi-currency-dollar"></i><a href="/sales">Sales</a></li>
            <li><i class="bi-card-list"></i><a href="/billing">Billing</a></li>
            <li><i class="bi-escape"></i><a href="{{logoutURL}}">Logout</a></li>
        </ul>
    </div>
    <div id="content">
        <div id="menu-bar">
            <div class="left-menu">
                <!-- Other menu items here -->
            </div>
            <div class="user-profile">
                <img src="https://via.placeholder.com/50" alt="User profile" />
                User profile
            </div>
        </div>

        <div>
            {{{body}}}
        </div>

    </div>
</body>

<script>

/*
    This script adds a .selected class to the <li> element of the current page's link in the sidebar.
    It uses the window.location.pathname property to get the path part of the current page's URL.
    It then compares this path with the path of each link in the sidebar.
    If the paths match, the .selected class is added to the parent <li> element of the link.

*/
document.addEventListener('DOMContentLoaded', function() {
    const links = document.querySelectorAll('#sidebar a');
    const currentPath = window.location.pathname; // Get the path part of the current page's URL
    console.log(currentPath);
    links.forEach(link => {
        const linkPath = link.pathname; // Get the path part of the link's URL
        console.log(linkPath);
        if (linkPath === currentPath) {
            link.parentElement.classList.add('selected'); // Add .selected class to parent <li> element
        }
    });
});
</script>

</html>